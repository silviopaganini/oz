{
  "name": "find-your-way-to-oz",
  "version": "1.0.0",
  "private": true,
  "description": "Modern dev/build wrapper for the legacy Find Your Way to Oz static site",
  "scripts": {
    "coffee:build:app": "node ./scripts/coffee-build.cjs app",
    "coffee:build:detect": "node ./scripts/coffee-build.cjs detect",
    "coffee:build": "npm-run-all coffee:build:app coffee:build:detect",
    "minify": "terser ./website/js/app.js -o ./website/js/app.min.js --compress --mangle && terser ./website/js/appDetect.js -o ./website/js/appDetect.min.js --compress --mangle",
    "coffee:watch:app": "node ./scripts/coffee-build.cjs app --watch",
    "coffee:watch:detect": "node ./scripts/coffee-build.cjs detect --watch",
    "less:build": "node ./scripts/less-build.cjs",
    "less:watch": "node ./scripts/less-watch.cjs",
    "assets:build": "npm-run-all coffee:build less:build",
    "assets:watch": "npm-run-all --parallel coffee:watch:app coffee:watch:detect less:watch",
    "vite:dev": "vite",
    "dev": "npm-run-all assets:build --parallel assets:watch vite:dev",
    "clean:dist": "node ./scripts/clean-dist.cjs",
    "verify:website": "node ./scripts/verify-build.cjs website",
    "verify:dist": "node ./scripts/verify-build.cjs dist",
    "vite:build": "vite build",
    "postbuild:dist": "node ./scripts/postbuild-dist.cjs",
    "build": "npm-run-all clean:dist assets:build minify verify:website vite:build postbuild:dist",
    "preview": "vite preview"
  },
  "devDependencies": {
    "coffee-script": "^1.12.7",
    "less": "^4.4.2",
    "npm-run-all": "^4.1.5",
    "terser": "^5.31.0",
    "vite": "^7.1.0"
  }
}
